{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rustwallhub",
  "version": "1.1.0",
  "identifier": "com.rustwallhub.app",
  "build": {
    "beforeDevCommand": "deno task dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "deno task build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RustWallhub - 壁纸管理器",
        "width": 1100,
        "height": 760,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://th.wallhaven.cc; style-src 'self' 'unsafe-inline'; connect-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.cache/rustwallhub/**",
          "$HOME/Pictures/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
